{
  "name": "Aardium",
  "productName": "Aardium",
  "version": "2.1.2",
  "description": "A minimal Electron app for Aardvark",
  "license": "MIT",
  "author": {
    "name": "The Aardvark Platform Team",
    "url": "http://aardvarkians.com"
  },
  "scripts": {
    "postinstall": "electron-rebuild node-shared-mem",
    "build": "node scripts/build.js",
    "build:win32:x64": "npm run build -- --platform=win32 --arch=x64",
    "build:linux:x64": "npm run build -- --platform=linux --arch=x64 && cd dist/Aardium-linux-x64 && tar -zcvf ../Aardium-Linux-x64.tar.gz .",
    "build:darwin:arm64": "npm run build -- --platform=darwin --arch=arm64 && cd dist/Aardium-darwin-arm64 && tar -zcvf ../Aardium-Darwin-arm64.tar.gz .",
    "build:darwin:x64": "npm run build -- --platform=darwin --arch=x64 && cd dist/Aardium-darwin-x64 && tar -zcvf ../Aardium-Darwin-x64.tar.gz ."
  },
  "main": "main.js",
  "repository": "https://github.com/aardvark-community/aardium",
  "dependencies": {
    "@electron/remote": "^2.1.0",
    "electron-localshortcut": "^3.2.1",
    "node-getopt": "^0.3.2",
    "node-shared-mem": "^2.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "dotenv": "^17.4.2",
    "electron": "42.3.0",
    "@electron/notarize": "^3.1.1",
    "@electron/packager": "^20.0.0"
  },
  "build": {
    "appId": "com.aardvarkians.aardium",
    "mac": {
      "category": "your.app.category.type",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "buildDependenciesFromSource": true,
    "afterSign": "scripts/notarize.js"
  }
}
